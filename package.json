{
    "name": "riza",
    "version": "3.0.44",
    "description": "Riza Library",
    "type": "module",
    "main": "./dist/riza.m.js",
    "module": "./dist/riza.m.js",
    "global": "./dist/riza.js",
    "types": "./dist/riza.d.ts",
    "bin": {
        "riza": "bin/cli.js"
    },
    "scripts": {
        "test": "echo Ok",
        "changes": "rose changes",
        "build:global": "parcel build --target global",
        "build:module": "parcel build --target module",
        "build": "shx rm -rf .parcel-cache && pnpm build:module && pnpm build:global",
        "parcel": "parcel"
    },
    "targets": {
        "main": false,
        "module": {
            "source": "./src/main.js",
            "optimize": true,
            "isLibrary": true
        },
        "global": {
            "source": "./src/_main.js",
            "optimize": true,
            "includeNodeModules": true,
            "isLibrary": true
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rsthn/riza.git"
    },
    "author": "RedStar Technologies",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/rsthn/riza/issues"
    },
    "homepage": "https://github.com/rsthn/riza#readme",
    "files": [
        "dist/",
        "bin/",
        "LICENSE",
        "README.md"
    ],
    "dependencies": {
        "base-64": "^1.0.0",
        "fs-extra": "^10.1.0",
        "rinn": "^2.0.54",
        "riza-signal": "^1.0.6"
    },
    "devDependencies": {
        "baseline-browser-mapping": "^2.10.24",
        "parcel": "^2.16.4",
        "shx": "^0.3.4"
    },
    "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}