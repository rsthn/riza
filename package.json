{
    "name": "riza",
    "version": "3.0.42",
    "description": "Riza Library",
    "type": "module",
    "main": "./dist/riza.m.js",
    "module": "./dist/riza.m.js",
    "global": "./dist/riza.js",
    "types": "./dist/riza.d.ts",
    "bin": {
        "riza": "bin/cli.js"
    },
    "scripts": {
        "test": "echo Ok",
        "changes": "rose changes",
        "build:global": "parcel build --target global",
        "build:module": "parcel build --target module",
        "build": "shx rm -rf .parcel-cache && pnpm build:module && pnpm build:global"
    },
    "targets": {
        "module": {
            "source": "./src/main.js",
            "optimize": true,
            "isLibrary": true
        },
        "global": {
            "source": "./src/_main.js",
            "optimize": true,
            "includeNodeModules": true,
            "isLibrary": true
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rsthn/riza.git"
    },
    "author": "RedStar Technologies",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/rsthn/riza/issues"
    },
    "homepage": "https://github.com/rsthn/riza#readme",
    "files": [
        "dist/",
        "bin/",
        "LICENSE",
        "README.md"
    ],
    "dependencies": {
        "base-64": "^1.0.0",
        "fs-extra": "^10.1.0",
        "rinn": "^2.0.52",
        "riza-signal": "^1.0.6"
    },
    "devDependencies": {
        "parcel": "^2.15.4",
        "shx": "^0.3.4"
    },
    "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
